# Compute Commons — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Google Cloud ──────────────────────────────────────────────────────────────
# Your GCP project ID (find it in console.cloud.google.com)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Service account credentials — choose ONE option:
#
# Option A (recommended for local dev):
#   1. Download a service account JSON key from:
#      IAM & Admin → Service Accounts → your-sa → Keys → Add Key → JSON
#   2. Set the path below:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
#
# Option B (gcloud CLI — no file needed):
#   Run: gcloud auth application-default login
#   Then comment out GOOGLE_APPLICATION_CREDENTIALS above.
#
# Option C (Cloud Run):
#   Attach a service account with roles/datastore.user to the Cloud Run service.
#   No env var needed — credentials are auto-discovered from the metadata server.

# ── Firestore ─────────────────────────────────────────────────────────────────
# Leave blank to use the default database, or set a named database ID
FIRESTORE_DATABASE=(default)

# To use the local Firestore emulator instead of GCP:
# 1. Install: gcloud components install cloud-firestore-emulator
# 2. Start:   gcloud emulators firestore start --host-port=localhost:8080
# 3. Set:
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins to allow IN ADDITION to the defaults
# (computecommons.io and localhost:3000/3001 are always included)
ALLOWED_ORIGINS=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to "production" to enable Firestore (vs in-memory store)
ENV=development
PORT=8080

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Twilio (notifications) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Algolia (contribution search) ─────────────────────────────────────────────
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=compute-commons-contributions
