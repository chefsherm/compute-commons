# Compute Commons — Backend Environment Variables
# Copy to .env for local development
# Set as Cloud Run environment variables in GCP console or via gcloud CLI

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- Firestore ---
FIRESTORE_DATABASE=(default)
# Set to "emulator" to use local Firestore emulator
FIRESTORE_EMULATOR_HOST=

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://computecommons.io,https://www.computecommons.io

# --- JWT Auth (Phase 2) ---
JWT_SECRET=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Twilio (notifications) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Algolia (search) ---
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=compute-commons-contributions

# --- Runtime ---
PORT=8080
ENV=production
